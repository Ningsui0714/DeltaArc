{
  "name": "game-wind-tunnel",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node --env-file-if-exists=.env.local --import tsx server/index.ts",
    "dev:full": "concurrently \"npm:dev\" \"npm:dev:server\"",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.build.json && node scripts/write-server-package.mjs",
    "build": "npm run build:client && npm run build:server",
    "start": "node --env-file-if-exists=.env.local dist-server/server/index.js",
    "test": "node --import tsx --test src/lib/import/parseJsonImport.test.ts server/lib/sandboxMemoryStore.test.ts shared/schema/sandboxResult.test.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json",
    "verify:fixtures": "tsx scripts/verify-fixtures.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "express": "^4.21.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^24.0.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.2",
    "typescript": "^5.6.3",
    "tsx": "^4.19.3",
    "vite": "^5.4.10"
  }
}
